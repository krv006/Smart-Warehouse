# .env.example — bu faylni nusxalab .env nomini bering
# va o'z qiymatlaringizni kiriting.

# Django
# SECRET_KEY — kuchli tasodifiy kalit. Yaratish:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
# Production'da HAR DOIM False (True bo'lsa xatolar to'liq ochiladi)
DEBUG=False
# Aniq domenlar (vergul bilan). Bo'sh + DEBUG=False → localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — frontend domenlari (vergul bilan). Production'da '*' emas, aniq manzil!
# Masalan: https://warehouse-eosin-six.vercel.app,https://smart.thesofmebel.uz
CORS_ALLOWED_ORIGINS=

# Ma'lumotlar bazasi (SQLite uchun DB_ENGINE ni bo'sh qoldiring)
DB_ENGINE=
DB_NAME=warehouse
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
