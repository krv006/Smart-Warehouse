# .env.example — bu faylni nusxalab .env nomini bering
# va o'z qiymatlaringizni kiriting.

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Ma'lumotlar bazasi (SQLite uchun DB_ENGINE ni bo'sh qoldiring)
DB_ENGINE=
DB_NAME=warehouse
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
